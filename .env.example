# ==============================================================================
# PIXELPAGE CHAT — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — credenciais ficam fora do repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# APP
# ------------------------------------------------------------------------------
# URL pública da aplicação (sem barra no final).
# Local: http://localhost:3000 | Produção: https://www.pixelpagechat.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# SUPABASE (obrigatório)
# Crie um projeto em https://supabase.com e copie de Settings > API
# ------------------------------------------------------------------------------
# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Chave anônima (anon/public) — usada no browser, protegida por RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service_role — SOMENTE no servidor (webhooks, API pública, admin).
# Ignora RLS. Nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# ADMIN
# ------------------------------------------------------------------------------
# Email que recebe a role 'admin' automaticamente ao se registrar
# (acesso ao painel /admin). Ex.: patrick@pixelpagechat.com.br
ADMIN_EMAIL=
# Email do Super Admin: além do painel /admin, enxerga TODOS os recursos de
# todos os planos (badge "visível como Super Admin" nos recursos liberados).
SUPERADMIN_EMAIL=

# ------------------------------------------------------------------------------
# GOOGLE OAUTH (login social "Entrar com Google")
# IMPORTANTE: o login com Google usa o provider nativo do Supabase Auth, então
# o Client ID e o Client Secret NÃO ficam aqui — eles são cadastrados no painel
# do Supabase: Authentication > Providers > Google. Lá você cola as credenciais
# criadas em https://console.cloud.google.com (OAuth 2.0 Client).
# Authorized redirect URI a configurar no Google Cloud:
#   https://SEU_PROJETO.supabase.co/auth/v1/callback
# Não existe NEXT_PUBLIC_GOOGLE_CLIENT_ID neste projeto — o fluxo é via Supabase.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# CLAUDE API (Bot IA nativo + simulador)
# Crie uma chave em https://console.anthropic.com
# Sem a chave, o simulador e o bot retornam erro amigável no painel.
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Modelo padrão do bot (pode ser sobrescrito em /admin > Configurações)
CLAUDE_MODEL=claude-haiku-4-5
# Máximo de tokens por resposta do bot
CLAUDE_MAX_TOKENS=1024
# Temperatura (0 a 1) — menor = mais determinístico
CLAUDE_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# OPENAI (provedor managed alternativo — org escolhe em Integrações > Modo de IA)
# Chave da CONTA GERENCIADA DA PLATAFORMA, não a chave própria do cliente (essa
# é BYOK, fica cifrada em org_secrets, não usa esta variável). Crie em
# https://platform.openai.com/api-keys
# Sem a chave, orgs com ai_provider="openai" em modo managed retornam erro
# amigável no painel (mesmo comportamento do ANTHROPIC_API_KEY ausente).
# ------------------------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# META / WHATSAPP CLOUD API (Tech Provider)
# Painel: https://developers.facebook.com/apps
# ------------------------------------------------------------------------------
# ID do app Meta (server-side)
META_APP_ID=
# App Secret — usado para validar a assinatura X-Hub-Signature-256 dos webhooks
META_APP_SECRET=
# Verify token do webhook — você inventa este valor e cola o MESMO no painel
# da Meta em WhatsApp > Configuration > Webhook (campo "Verify token")
META_WEBHOOK_VERIFY_TOKEN=
# Token de System User do Tech Provider (global, permanente) — usado para
# enviar mensagens em nome de todos os clientes conectados
META_SYSTEM_USER_TOKEN=
# Versão da Graph API
META_GRAPH_VERSION=v21.0

# --- Embedded Signup (client-side) ---
# ID do app Meta exposto ao browser (mesmo valor do META_APP_ID)
NEXT_PUBLIC_META_APP_ID=
# Configuration ID do Embedded Signup (Facebook Login for Business >
# Configurations no painel da Meta)
NEXT_PUBLIC_META_CONFIG_ID=
# Versão da Graph API usada pelo SDK no browser (igual ao META_GRAPH_VERSION)
NEXT_PUBLIC_META_GRAPH_VERSION=v21.0
# Feature flag: "true" habilita o botão de conexão via Embedded Signup.
# Enquanto o app Meta estiver em análise, deixe "false" — o onboarding mostra
# o card "disponível em breve" e permite pular a etapa.
NEXT_PUBLIC_EMBEDDED_SIGNUP_ENABLED=false

# ------------------------------------------------------------------------------
# EVOLUTION API (conexão WhatsApp via QR Code)
# Instância self-hosted ou cloud da Evolution API (evolution-api.com).
# Também configurável pelo painel /admin > Configurações (env tem prioridade).
# ------------------------------------------------------------------------------
# URL base da sua Evolution API. Ex.: https://evo.seudominio.com.br
EVOLUTION_API_URL=
# API Key global da Evolution API (AUTHENTICATION_API_KEY da instância)
EVOLUTION_API_KEY=
# Token que protege o webhook /api/webhooks/evolution (você inventa este valor;
# ele é incluído na URL do webhook registrada em cada instância)
EVOLUTION_WEBHOOK_TOKEN=

# ------------------------------------------------------------------------------
# N8N (workflow pronto da plataforma)
# URL do webhook do workflow de atendimento hospedado pela própria plataforma
# (n8n cloud). Mostrado ao cliente quando ele ativa o "workflow pronto" em
# Conexões → Configurar webhook. Tem um padrão sensato se não for definido.
# ------------------------------------------------------------------------------
PLATFORM_N8N_WEBHOOK_URL=https://pixelpage.app.n8n.cloud/webhook/pixelpage-atendimento

# ------------------------------------------------------------------------------
# STRIPE (cobrança — único provider de pagamento)
# https://dashboard.stripe.com/apikeys — chave secreta (sk_...).
# Execute scripts/create-stripe-products.ts para criar os produtos/preços e
# gravar automaticamente plans.stripe_price_id.
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=

# Segredo do endpoint de webhook (dashboard Stripe → Webhooks → sua URL →
# "Signing secret", whsec_...). Nunca commite o valor real.
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# CRON (campanhas agendadas, CSAT com atraso, fluxos "Aguardar" e automações)
# A Vercel chama GET /api/campaigns/run e GET /api/jobs/run a cada minuto
# (vercel.json) enviando Authorization: Bearer {CRON_SECRET}.
# Defina um valor aleatório longo.
# ------------------------------------------------------------------------------
CRON_SECRET=

# ------------------------------------------------------------------------------
# EMAIL (opcional — ação "Notificar equipe por email" das automações)
# Sem estas variáveis, o alerta fica registrado apenas na trilha de auditoria.
# Crie uma chave em https://resend.com
# ------------------------------------------------------------------------------
RESEND_API_KEY=
# Remetente verificado no Resend. Ex.: PixelPage Chat <alertas@pixelpagechat.com.br>
NOTIFY_EMAIL_FROM=

# ------------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (captcha em /register, /login e /forgot-password)
# Crie um widget em https://dash.cloudflare.com > Turnstile > Add widget
# (modo "Managed"), domínio pixelpagechat.com.br + localhost.
# A Secret Key também precisa ser colada em Supabase Dashboard >
# Authentication > Attack Protection > Captcha secret (habilite a proteção lá).
# Em desenvolvimento (NODE_ENV !== "production") o app ignora estas variáveis
# e usa a sitekey de teste do Cloudflare, que sempre passa — não é necessário
# preenchê-las para rodar localmente.
# ------------------------------------------------------------------------------
# Site Key (pública) — usada no browser
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret Key — não é lida pelo código: o Supabase valida o captchaToken
# internamente usando o valor colado no painel dele. Mantida aqui só como
# referência do par de chaves; cole o valor real apenas na Vercel.
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------------------
# DESENVOLVIMENTO
# ------------------------------------------------------------------------------
# "true" habilita a rota POST /api/dev/seed que popula conversas/contatos de
# exemplo na organização do usuário logado. Desative em produção.
DEV_SEED_ENABLED=true
